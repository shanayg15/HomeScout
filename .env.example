# Toggle: when true, the app returns mock dossiers (no external calls). Default true.
USE_MOCKS=true

# Core property data (RentCast). Free Developer tier = 50 calls/month.
# Get a key: https://www.rentcast.io/api  → then set USE_MOCKS=false for real data.
RENTCAST_API_KEY=

# Walkability (Walk Score). Free key, ~5,000/day. Unlocks Walk/Transit/Bike scores.
# Get a key: https://www.walkscore.com/professional/api.php
WALKSCORE_API_KEY=

# Demographics (US Census ACS). Free key — now REQUIRED for ACS data (the
# geocoder stays keyless). Unlocks median income + owner-occupied rate.
# Get a key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# Crime context: currently OMITTED by design (only state-level data exists, too
# coarse to present responsibly per property). This key is reserved/unused.
FBI_CRIME_API_KEY=

# AI explanations (Anthropic). Optional — unlocks zoning plain-English + the
# deal-read narrative. Without it, the deterministic math still shows.
# Get a key: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Cache TTL in days for real lookups (default 7).
CACHE_TTL_DAYS=7

# Map tiles (optional). If unset, the map uses free OpenStreetMap raster tiles.
# Get a free key at https://www.maptiler.com/ for nicer vector tiles.
MAPTILER_API_KEY=

# FEMA flood (National Flood Hazard Layer) needs NO key — always on.
